# Token server — proxy to LiveKit token endpoint
# Copy to e.g. token.yourdomain.com.conf or use as a location block on your app server.
# Token server runs on port 3001; CORS is handled by the app (ALLOWED_ORIGINS in .env).

server {
    listen 443 ssl http2;
    server_name token.YOUR_DOMAIN;

    ssl_certificate /path/to/ssl/fullchain.pem;
    ssl_certificate_key /path/to/ssl/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# Optional: HTTP redirect to HTTPS
# server {
#     listen 80;
#     server_name token.YOUR_DOMAIN;
#     return 301 https://$server_name$request_uri;
# }
