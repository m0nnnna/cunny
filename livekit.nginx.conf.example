# LiveKit server — WebSocket proxy
# Copy to e.g. livekit.yourdomain.com.conf and fill in the placeholders.
# Enable: include this in http {} or symlink into sites-enabled.

server {
    listen 443 ssl http2;
    server_name livekit.YOUR_DOMAIN;

    ssl_certificate /path/to/ssl/fullchain.pem;
    ssl_certificate_key /path/to/ssl/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:7880;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}

# Optional: HTTP redirect to HTTPS
# server {
#     listen 80;
#     server_name livekit.YOUR_DOMAIN;
#     return 301 https://$server_name$request_uri;
# }
