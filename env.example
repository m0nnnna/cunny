# LiveKit Configuration
# Keys are auto-generated by deploy.ps1 / setup.sh on every build.
# You should NOT need to set these manually. If you do, both services
# read from these env vars (docker-compose passes LIVEKIT_KEYS to LiveKit server).
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Your server's public IP or domain
HOST_IP=your-server-ip

# LiveKit WebSocket URL (for Cunny to connect)
# Use wss:// for production with SSL, ws:// for local development
LIVEKIT_WS_URL=wss://your-domain.com:7880

# Token endpoint URL (accessible from browser)
TOKEN_ENDPOINT=https://your-domain.com/api/livekit/token

# CORS - allowed origins for token server (browser must send requests from one of these)
# Use * for all, or exact origins, or one pattern: https://*.yourdomain.com (matches https://chat.yourdomain.com etc.)
ALLOWED_ORIGINS=https://*.yourdomain.com

# Optional: custom app name shown in the UI (tab title, login screen, about, etc.). Does not affect internal keys or storage.
# Set when building the web client (e.g. docker compose build --build-arg VITE_BRAND_NAME=MyApp).
# You can also set "brandName" in config.json at runtime to override without rebuilding.
VITE_BRAND_NAME=Cunny
